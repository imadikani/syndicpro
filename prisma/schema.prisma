// SyndicPro — Prisma Schema
// Database: PostgreSQL (Railway)
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  password  String // hashed with bcrypt
  role      Role     @default(SYNDIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings      Building[]      // buildings this user manages
  passwordResets PasswordReset[]

  @@map("users")
}

enum Role {
  ADMIN // you (super admin)
  SYNDIC // building manager
  RESIDENT // resident (future mobile app login)
}

// ─── BUILDINGS ────────────────────────────────────────────────────────────────

model Building {
  id         String   @id @default(cuid())
  name       String
  address    String
  city       String
  totalUnits Int
  monthlyFee Float // default charge in MAD
  color      String   @default("#4F8EF7")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  managedBy User   @relation(fields: [userId], references: [id])
  userId    String

  units          Unit[]
  expenses       Expense[]
  communityPosts CommunityPost[]

  @@map("buildings")
}

// ─── UNITS ────────────────────────────────────────────────────────────────────

model Unit {
  id         String   @id @default(cuid())
  number     String // e.g. "A3", "2B"
  floor      Int?
  monthlyFee Float? // override building default if needed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId String

  resident Resident?
  payments Payment[]

  @@unique([buildingId, number])
  @@map("units")
}

// ─── RESIDENTS ────────────────────────────────────────────────────────────────

model Resident {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  isOwner   Boolean  @default(false) // owner vs tenant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId String @unique

  reminders      Reminder[]
  communityPosts CommunityPost[]

  @@map("residents")
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────────

model Payment {
  id            String         @id @default(cuid())
  month         Int            // MONTHLY: 1–12; QUARTERLY: quarter-start month; ANNUAL: 0
  year          Int            // billing year
  chargeMonth   Int?           // 1–12 for display; null for ANNUAL
  billingPeriod String         @default("MONTHLY") // MONTHLY | QUARTERLY | ANNUAL
  periodLabel   String?        // e.g. "Avril 2026", "Q2 2026", "Année 2026"
  amount        Float          // in MAD
  status        PaymentStatus  @default(PENDING)
  method        PaymentMethod?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId String

  @@unique([unitId, year, month, billingPeriod])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  LATE // paid but after due date
  WAIVED // syndic waived the fee
}

enum PaymentMethod {
  VIREMENT // bank transfer
  CMI // card online (future Payzone)
  CASH // cash in hand
  CHEQUE
}

// ─── EXPENSES ─────────────────────────────────────────────────────────────────

model Expense {
  id         String          @id @default(cuid())
  label      String
  amount     Float
  category   ExpenseCategory
  date       DateTime
  dueDate    DateTime? // when bill must be paid
  isPaid     Boolean         @default(true)
  notes      String?
  receiptUrl String?
  createdAt  DateTime        @default(now())

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId String

  @@map("expenses")
}

enum ExpenseCategory {
  ENTRETIEN // maintenance
  REPARATION // repair
  SECURITE // security / gardien
  ELECTRICITE
  EAU
  ASSURANCE
  AUTRE
}

// ─── REMINDERS ────────────────────────────────────────────────────────────────

model Reminder {
  id      String          @id @default(cuid())
  channel ReminderChannel @default(WHATSAPP)
  status  ReminderStatus  @default(SENT)
  message String
  sentAt  DateTime        @default(now())

  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId String

  @@map("reminders")
}

enum ReminderChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum ReminderStatus {
  SENT
  DELIVERED
  FAILED
}

// ─── DEMO REQUESTS ────────────────────────────────────────────────────────────

model DemoRequest {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  phone     String?
  buildings Int?
  plan      String?
  message   String?
  createdAt DateTime @default(now())
  contacted Boolean  @default(false)
}

// ─── RESIDENT PORTAL ──────────────────────────────────────────────────────────

model ResidentOtp {
  id        String   @id @default(cuid())
  phone     String
  pinHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("resident_otps")
}

model CommunityPost {
  id         String   @id @default(cuid())
  content    String
  authorName String // display name (resident first name or "Syndic")
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId String

  resident   Resident? @relation(fields: [residentId], references: [id])
  residentId String?

  @@map("community_posts")
}

// ─── PASSWORD RESET ───────────────────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  code      String   // 6-digit code
  method    String   // EMAIL | WHATSAPP
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("password_resets")
}
