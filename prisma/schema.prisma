// SyndicPro — Prisma Schema
// Database: PostgreSQL (Railway)
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  password  String   // hashed with bcrypt
  role      Role     @default(SYNDIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildings Building[] // buildings this user manages

  @@map("users")
}

enum Role {
  ADMIN    // you (super admin)
  SYNDIC   // building manager
  RESIDENT // resident (future mobile app login)
}

// ─── BUILDINGS ────────────────────────────────────────────────────────────────

model Building {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  totalUnits  Int
  monthlyFee  Float    // default charge in MAD
  color       String   @default("#4F8EF7")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  managedBy   User     @relation(fields: [userId], references: [id])
  userId      String

  units       Unit[]
  expenses    Expense[]

  @@map("buildings")
}

// ─── UNITS ────────────────────────────────────────────────────────────────────

model Unit {
  id          String    @id @default(cuid())
  number      String    // e.g. "A3", "2B"
  floor       Int?
  monthlyFee  Float?    // override building default if needed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  building    Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId  String

  resident    Resident?
  payments    Payment[]

  @@unique([buildingId, number])
  @@map("units")
}

// ─── RESIDENTS ────────────────────────────────────────────────────────────────

model Resident {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  isOwner   Boolean  @default(false) // owner vs tenant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId    String   @unique

  reminders Reminder[]

  @@map("residents")
}

// ─── PAYMENTS ─────────────────────────────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  month       Int           // 1–12
  year        Int
  amount      Float         // in MAD
  status      PaymentStatus @default(PENDING)
  method      PaymentMethod?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  unit        Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId      String

  @@unique([unitId, month, year])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  LATE      // paid but after due date
  WAIVED    // syndic waived the fee
}

enum PaymentMethod {
  VIREMENT   // bank transfer
  CMI        // card online (future Payzone)
  CASH       // cash in hand
  CHEQUE
}

// ─── EXPENSES ─────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  label       String
  amount      Float
  category    ExpenseCategory
  date        DateTime
  notes       String?
  receiptUrl  String?         // uploaded receipt (future S3)
  createdAt   DateTime        @default(now())

  building    Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  buildingId  String

  @@map("expenses")
}

enum ExpenseCategory {
  ENTRETIEN    // maintenance
  REPARATION   // repair
  SECURITE     // security / gardien
  ELECTRICITE
  EAU
  ASSURANCE
  AUTRE
}

// ─── REMINDERS ────────────────────────────────────────────────────────────────

model Reminder {
  id          String         @id @default(cuid())
  channel     ReminderChannel @default(WHATSAPP)
  status      ReminderStatus @default(SENT)
  message     String
  sentAt      DateTime       @default(now())

  resident    Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  residentId  String

  @@map("reminders")
}

enum ReminderChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum ReminderStatus {
  SENT
  DELIVERED
  FAILED
}

// Add this model to your existing prisma/schema.prisma
// Place it after the existing models

model DemoRequest {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  phone     String?
  buildings Int?
  plan      String?
  message   String?
  createdAt DateTime @default(now())
  contacted Boolean  @default(false)
}

